generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  LEADER
  MEMBER
}

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  TENTATIVE
}

enum SlotRole {
  DPS
  SUPPORT
  FLEX
  OTHER
}

enum ScheduleStatus {
  DRAFT
  OPEN
  CONFIRMED
  COMPLETED
  CANCELED
}

enum ConfirmationStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

enum RaidSetStatus {
  DRAFT
  SCHEDULED
  CONFIRMED
  CANCELED
}

enum AvailabilityPresetMode {
  WEEKLY
  CYCLE
}

enum RaidSignupStatus {
  OPEN
  ASSIGNING
  FINALIZED
  CANCELED
}

enum RaidSignupEntryStatus {
  APPLIED
  CANCELED
  ASSIGNED
  FAILED
}

model Group {
  id            String             @id @default(cuid())
  name          String
  inviteCode    String             @unique
  inviteEnabled Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  members       Member[]
  templates     RaidTemplate[]
  schedules     Schedule[]
  notifications NotificationJob[]
  settings      GroupSettings?
  activityLogs  GroupActivityLog[]
  raidSets      RaidSet[]
  signups       RaidSignup[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  memberships  Member[]
}

model Member {
  id                         String                     @id @default(cuid())
  groupId                    String
  group                      Group                      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId                     String?
  user                       User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  nickname                   String
  role                       MemberRole                 @default(MEMBER)
  discordUserId              String?
  discordConnectedAt         DateTime?
  characterSyncFailedAt      DateTime?
  characterSyncFailureReason String?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt
  characters                 Character[]
  availabilityBlocks         AvailabilityBlock[]
  createdSchedules           Schedule[]                 @relation("ScheduleCreator")
  assignedSlots              ScheduleSlot[]
  notifications              NotificationJob[]
  scheduleAttendances        ScheduleAttendance[]
  permissions                MemberPermission?
  activityLogs               GroupActivityLog[]
  createdRaidSets            RaidSet[]
  raidSetSlots               RaidSetSlot[]
  availabilityPresets        AvailabilityPreset[]
  availabilityWeekOverrides  AvailabilityWeekOverride[]
  signupEntries              RaidSignupEntry[]
  createdSignups             RaidSignup[]

  @@unique([groupId, nickname])
  @@unique([groupId, userId])
  @@index([userId])
}

model Character {
  id            String               @id @default(cuid())
  memberId      String
  member        Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  name          String
  className     String
  itemLevel     Float
  preferredRole SlotRole
  notes         String               @default("")
  serverName    String               @default("")
  combatPower   Int?
  isMain        Boolean              @default(false)
  lastSyncedAt  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  scheduleSlots ScheduleSlot[]
  raidChecks    CharacterRaidCheck[]
  raidSetSlots  RaidSetSlot[]
  signupEntries RaidSignupEntry[]
}

model AvailabilityBlock {
  id        String             @id @default(cuid())
  memberId  String
  member    Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  date      DateTime
  startsAt  DateTime
  endsAt    DateTime
  status    AvailabilityStatus
  memo      String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([memberId, date])
}

model RaidTemplate {
  id                  String               @id @default(cuid())
  groupId             String
  group               Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name                String
  difficulty          String
  gates               String
  requiredPlayers     Int
  requirements        String               @default("")
  notes               String               @default("")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  slots               RaidTemplateSlot[]
  schedules           Schedule[]
  characterRaidChecks CharacterRaidCheck[]
  raidSets            RaidSet[]
  signups             RaidSignup[]
}

model CharacterRaidCheck {
  id             String       @id @default(cuid())
  characterId    String
  character      Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  raidTemplateId String
  raidTemplate   RaidTemplate @relation(fields: [raidTemplateId], references: [id], onDelete: Cascade)
  weekStartDate  String
  completedAt    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([characterId, raidTemplateId, weekStartDate])
  @@index([raidTemplateId])
  @@index([weekStartDate])
}

model RaidTemplateSlot {
  id              String         @id @default(cuid())
  templateId      String
  template        RaidTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label           String
  role            SlotRole
  required        Boolean        @default(true)
  classPreference String?
  notes           String         @default("")
  scheduleSlots   ScheduleSlot[]
}

model Schedule {
  id                String               @id @default(cuid())
  groupId           String
  group             Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  templateId        String
  template          RaidTemplate         @relation(fields: [templateId], references: [id])
  title             String
  startsAt          DateTime
  endsAt            DateTime?
  status            ScheduleStatus       @default(OPEN)
  notes             String               @default("")
  createdByMemberId String
  createdBy         Member               @relation("ScheduleCreator", fields: [createdByMemberId], references: [id])
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  slots             ScheduleSlot[]
  notifications     NotificationJob[]
  attendances       ScheduleAttendance[]
}

model ScheduleAttendance {
  id         String             @id @default(cuid())
  scheduleId String
  schedule   Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  status     ConfirmationStatus @default(PENDING)
  memo       String             @default("")
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([scheduleId, memberId])
  @@index([memberId])
}

model ScheduleSlot {
  id                  String             @id @default(cuid())
  scheduleId          String
  schedule            Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  templateSlotId      String?
  templateSlot        RaidTemplateSlot?  @relation(fields: [templateSlotId], references: [id])
  label               String
  role                SlotRole
  assignedMemberId    String?
  assignedMember      Member?            @relation(fields: [assignedMemberId], references: [id])
  assignedCharacterId String?
  assignedCharacter   Character?         @relation(fields: [assignedCharacterId], references: [id])
  confirmationStatus  ConfirmationStatus @default(PENDING)
  notes               String             @default("")
}

model NotificationJob {
  id            String             @id @default(cuid())
  groupId       String
  group         Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  memberId      String
  member        Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  scheduleId    String?
  schedule      Schedule?          @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  type          String
  message       String
  sendAfter     DateTime
  status        NotificationStatus @default(PENDING)
  failureReason String?
  attempts      Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model GroupSettings {
  id                              String   @id @default(cuid())
  groupId                         String   @unique
  group                           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  timetableStartHour              Int      @default(8)
  timetableEndHour                Int      @default(4)
  dailyDiscordSummaryEnabled      Boolean  @default(false)
  dailyDiscordSummaryTime         String   @default("09:00")
  raidReminderLeadMinutes         Int      @default(60)
  availabilityChangeNoticeEnabled Boolean  @default(false)
  discordChannelId                String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model MemberPermission {
  id                         String  @id @default(cuid())
  memberId                   String  @unique
  member                     Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  canManageSets              Boolean @default(false)
  canConfirmSchedules        Boolean @default(false)
  canEditSchedules           Boolean @default(false)
  canManageHomeworkForOthers Boolean @default(false)
  canManageSettings          Boolean @default(false)
}

model GroupActivityLog {
  id            String   @id @default(cuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actorMemberId String?
  actorMember   Member?  @relation(fields: [actorMemberId], references: [id], onDelete: SetNull)
  actionType    String
  targetType    String
  targetId      String?
  summary       String
  createdAt     DateTime @default(now())

  @@index([groupId, createdAt])
}

model RaidSet {
  id                String                 @id @default(cuid())
  groupId           String
  group             Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  templateId        String
  template          RaidTemplate           @relation(fields: [templateId], references: [id])
  label             String
  weekStartDate     String
  status            RaidSetStatus          @default(DRAFT)
  pinned            Boolean                @default(false)
  scheduledStartsAt DateTime?
  createdByMemberId String
  createdBy         Member                 @relation(fields: [createdByMemberId], references: [id])
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  slots             RaidSetSlot[]
  signupAssignments RaidSignupAssignment[]
  signupEntries     RaidSignupEntry[]      @relation("RaidSignupEntryAssignedSet")

  @@index([groupId, weekStartDate])
  @@index([templateId])
}

model RaidSetSlot {
  id                  String     @id @default(cuid())
  raidSetId           String
  raidSet             RaidSet    @relation(fields: [raidSetId], references: [id], onDelete: Cascade)
  order               Int
  label               String
  role                SlotRole
  assignedMemberId    String?
  assignedMember      Member?    @relation(fields: [assignedMemberId], references: [id])
  assignedCharacterId String?
  assignedCharacter   Character? @relation(fields: [assignedCharacterId], references: [id])
  absent              Boolean    @default(false)
  absentReason        String     @default("")
  roleOverride        SlotRole?

  @@index([raidSetId, order])
}

model AvailabilityPreset {
  id         String                   @id @default(cuid())
  memberId   String
  member     Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  name       String
  mode       AvailabilityPresetMode
  cycleDays  Int?
  anchorDate String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt
  slots      AvailabilityPresetSlot[]

  @@index([memberId])
}

model AvailabilityPresetSlot {
  id        String             @id @default(cuid())
  presetId  String
  preset    AvailabilityPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  dayOfWeek Int?
  cycleDay  Int?
  startTime String
  endTime   String
}

model AvailabilityWeekOverride {
  id            String   @id @default(cuid())
  memberId      String
  member        Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  weekStartDate String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([memberId, weekStartDate])
}

model RaidSignup {
  id                String                 @id @default(cuid())
  groupId           String
  group             Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  templateId        String
  template          RaidTemplate           @relation(fields: [templateId], references: [id])
  title             String
  weekStartDate     String
  partySize         Int
  maxParties        Int
  status            RaidSignupStatus       @default(OPEN)
  createdByMemberId String
  createdBy         Member                 @relation(fields: [createdByMemberId], references: [id])
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  entries           RaidSignupEntry[]
  assignments       RaidSignupAssignment[]

  @@index([groupId, weekStartDate])
}

model RaidSignupEntry {
  id                String                @id @default(cuid())
  signupId          String
  signup            RaidSignup            @relation(fields: [signupId], references: [id], onDelete: Cascade)
  memberId          String
  member            Member                @relation(fields: [memberId], references: [id], onDelete: Cascade)
  characterId       String
  character         Character             @relation(fields: [characterId], references: [id], onDelete: Cascade)
  status            RaidSignupEntryStatus @default(APPLIED)
  memo              String                @default("")
  assignedRaidSetId String?
  assignedRaidSet   RaidSet?              @relation("RaidSignupEntryAssignedSet", fields: [assignedRaidSetId], references: [id], onDelete: SetNull)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@unique([signupId, characterId])
  @@index([memberId])
  @@index([assignedRaidSetId])
}

model RaidSignupAssignment {
  id          String     @id @default(cuid())
  signupId    String
  signup      RaidSignup @relation(fields: [signupId], references: [id], onDelete: Cascade)
  raidSetId   String
  raidSet     RaidSet    @relation(fields: [raidSetId], references: [id], onDelete: Cascade)
  partyNumber Int
  createdAt   DateTime   @default(now())

  @@unique([signupId, raidSetId])
}
